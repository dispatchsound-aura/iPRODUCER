generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         String   @default("SUBSCRIBER") // "ADMIN", "SUBSCRIBER"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// These models ensure your existing iPRODUCE app pages
// don't break when fetching Generation or Crate data.
model Generation {
  id        String   @id @default(cuid())
  taskId    String?
  status    String   @default("pending")
  beatUrl   String?
  prompt    String
  title     String?
  crateId   String?
  bpm       Int?
  userId    String?
  folderId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Crate {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
